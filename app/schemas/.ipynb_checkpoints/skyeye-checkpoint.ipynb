    "    symbol: str = Field(..., description=\"圖形，可選值: circle, rect, roundRect, triangle, diamond, pin, arrow, none\")\n",
    "    color: str = Field(..., description=\"顏色，可接受 #RRGGBBAA, #RRGGBB 或 colorname\")\n",
    "\n",
    "class DefectCategoryResponse(BaseModel):\n",
