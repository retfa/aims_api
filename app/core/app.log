SELECT jobs.JobID, jobs.klKey, defect.DefectNameDetail
FROM [srvmsdba1].[FlawInspection].[dbo].[duptjobs] jobs
CROSS JOIN ##AllDefectNames defect
WHERE jobs.JobID IN (SELECT value FROM STRING_SPLIT(@JobID, ','))
        ]
